# System Requirements
NODE_ENV=production

# URLs (Update these for production matching your Nginx setup)
PUBLIC_WEB_URL=http://localhost
ADMIN_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:5000

# API Secrets
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=your_super_secret_access_token
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token

# Seed Data Defaults (Change before running pnpm db:seed)
SEED_ADMIN_EMAIL=admin@brikienlabs.tech
SEED_ADMIN_PASSWORD=adminpassword
